  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Font Settings"
      },
      {
        "type": "select",
        "id": "type_header_font",
        "label": "Heading Font",
        "options": [
          { "value": "Epilogue", "label": "Epilogue (Default)" },
          { "value": "Playfair Display", "label": "Playfair Display" },
          { "value": "Cormorant Garamond", "label": "Cormorant Garamond" }
        ],
        "default": "Epilogue"
      },
      {
        "type": "select",
        "id": "type_body_font",
        "label": "Body Font",
        "options": [
          { "value": "Manrope", "label": "Manrope (Default)" },
          { "value": "Inter", "label": "Inter" },
          { "value": "DM Sans", "label": "DM Sans" }
        ],
        "default": "Manrope"
      },
      {
        "type": "range",
        "id": "type_base_size",
        "label": "Base Font Size",
        "min": 14,
        "max": 20,
        "step": 1,
        "default": 16,
        "unit": "px"
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo Image"
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "label": "Logo Max Width",
        "min": 50,
        "max": 300,
        "step": 10,
        "default": 160,
        "unit": "px"
      },
      {
        "type": "text",
        "id": "logo_text",
        "label": "Logo Text (if no image)",
        "default": "FAITHFUL OCCASIONS"
      },
      {
        "type": "link_list",
        "id": "main_menu",
        "label": "Main Navigation Menu",
        "default": "main-menu"
      },
      {
        "type": "checkbox",
        "id": "header_sticky",
        "label": "Sticky Header",
        "default": true
      }
    ]
  },
  {
