        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "url",
        "id": "social_pinterest",
        "label": "Pinterest URL"
      },
      {
        "type": "url",
        "id": "social_youtube",
        "label": "YouTube URL"
      }
    ]
