<section class="newsletter" {{ section.shopify_attributes }}>
  <div class="newsletter__inner">
    <div class="newsletter__content">
      {%- if section.settings.eyebrow != blank -%}
        <span class="newsletter__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="newsletter__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtext != blank -%}
        <p class="newsletter__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>
    <div class="newsletter__form-wrap">
      {%- form 'customer', id: 'NewsletterForm' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {%- if form.posted_successfully? -%}
          <p class="newsletter__success">{{ 'newsletter.subscribe' | t | default: 'Thank you for subscribing!' }}</p>
        {%- else -%}
          <div class="newsletter__form">
            <input
              class="newsletter__input"
              type="email"
              name="contact[email]"
              id="NewsletterForm-email"
              value="{{ form.email }}"
              placeholder="{{ section.settings.placeholder | default: 'YOUR@EMAIL.COM' }}"
              autocomplete="email"
              required
            >
            <button class="btn btn--primary newsletter__btn" type="submit">
              {{ section.settings.button_text | default: 'SUBSCRIBE' | upcase }}
            </button>
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .newsletter {
    background-color: var(--color-primary-container);
    padding: 5rem 0;
  }

  .newsletter__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .newsletter__eyebrow {
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 0.65rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--color-secondary);
    display: block;
    margin-bottom: 1rem;
  }

  .newsletter__heading {
    font-family: 'Epilogue', sans-serif;
    font-weight: 900;
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    text-transform: uppercase;
    color: var(--color-inverse-on-surface);
    margin: 0 0 0.75rem;
    line-height: 1.1;
  }

  .newsletter__subtext {
    font-family: 'Manrope', sans-serif;
    font-size: 0.95rem;
    line-height: 1.65;
    color: rgba(255, 238, 219, 0.65);
    margin: 0;
    max-width: 380px;
  }

  .newsletter__form {
    display: flex;
    gap: 0;
  }

  .newsletter__input {
    flex: 1;
    background-color: rgba(255, 248, 244, 0.1);
    border: 2px solid rgba(255, 238, 219, 0.3);
    border-right: none;
    padding: 1rem 1.25rem;
    font-family: 'Manrope', sans-serif;
    font-size: 0.9rem;
    color: var(--color-inverse-on-surface);
    outline: none;
    transition: border-color 0.3s ease;
  }

  .newsletter__input::placeholder {
    color: rgba(255, 238, 219, 0.4);
  }

  .newsletter__input:focus {
    border-color: rgba(255, 238, 219, 0.6);
  }

  .newsletter__btn {
    flex-shrink: 0;
    white-space: nowrap;
  }

  .newsletter__success {
    font-family: 'Manrope', sans-serif;
    font-size: 1rem;
    color: var(--color-inverse-on-surface);
    padding: 1rem;
    background-color: rgba(255, 238, 219, 0.1);
    text-align: center;
  }

  @media (max-width: 768px) {
    .newsletter__inner { grid-template-columns: 1fr; gap: 2rem; }
    .newsletter__form { flex-direction: column; }
    .newsletter__input { border-right: 2px solid rgba(255, 238, 219, 0.3); border-bottom: none; }
    .newsletter__btn { width: 100%; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "shopify-section--newsletter",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "JOIN THE COMMUNITY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NEW KITS & RESOURCES EVERY MONTH"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Supporting Text",
      "default": "Get free planning tips, new product announcements, and exclusive discounts sent straight to your inbox."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email Placeholder",
      "default": "YOUR@EMAIL.COM"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SUBSCRIBE"
    }
  ],
  "presets": [
    {
      "name": "Newsletter Signup"
    }
  ]
}
{% endschema %}
