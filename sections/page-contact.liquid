<!-- ============================================================
   CONTACT PAGE SECTION
   Two-column layout: left (heading + service list), right (form)
   ============================================================ -->

<section class="contact-section" {{ section.shopify_attributes }}>
  <div class="contact-section__inner">

    <!-- LEFT COLUMN -->
    <div class="contact-section__left">
      <h1 class="contact-section__heading">{{ section.settings.heading }}</h1>

      <p class="contact-section__intro">{{ section.settings.intro_text }}</p>

      <ul class="contact-section__services">
        {% if section.settings.service_1 != blank %}
          <li>{{ section.settings.service_1 }}</li>
        {% endif %}
        {% if section.settings.service_2 != blank %}
          <li>{{ section.settings.service_2 }}</li>
        {% endif %}
        {% if section.settings.service_3 != blank %}
          <li>{{ section.settings.service_3 }}</li>
        {% endif %}
        {% if section.settings.service_4 != blank %}
          <li>{{ section.settings.service_4 }}</li>
        {% endif %}
        {% if section.settings.service_5 != blank %}
          <li>{{ section.settings.service_5 }}</li>
        {% endif %}
      </ul>
    </div>

    <!-- RIGHT COLUMN — CONTACT FORM -->
    <div class="contact-section__right">
      <div class="contact-card">
      {% form 'contact', id: 'ContactForm', class: 'contact-form' %}

        {{ form.errors | default_errors }}

        {% if form.posted_successfully? %}
          <p class="contact-form__success">{{ section.settings.success_message }}</p>
        {% endif %}

        <!-- Full Name -->
        <div class="contact-form__field">
          <label class="contact-form__label" for="ContactForm-name">
            {{ section.settings.label_name }}
          </label>
          <input
            class="contact-form__input"
            type="text"
            id="ContactForm-name"
            name="contact[name]"
            autocomplete="name"
            placeholder="{{ section.settings.placeholder_name }}"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            required
          >
        </div>

        <!-- Email Address -->
        <div class="contact-form__field">
          <label class="contact-form__label" for="ContactForm-email">
            {{ section.settings.label_email }}
          </label>
          <input
            class="contact-form__input"
            type="email"
            id="ContactForm-email"
            name="contact[email]"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            placeholder="{{ section.settings.placeholder_email }}"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            required
          >
        </div>

        <!-- I Am Interested In -->
        <div class="contact-form__field">
          <label class="contact-form__label" for="ContactForm-interest">
            {{ section.settings.label_interest }}
          </label>
          <div class="contact-form__select-wrap">
            <select
              class="contact-form__select"
              id="ContactForm-interest"
              name="contact[interested_in]"
            >
              <option value="" disabled selected>{{ section.settings.placeholder_interest }}</option>
              <option value="Custom Retreat Planning">{{ section.settings.service_1 }}</option>
              <option value="Day-Of Coordination">{{ section.settings.service_2 }}</option>
              <option value="Planning Consultation">{{ section.settings.service_3 }}</option>
              <option value="Full Event Management">{{ section.settings.service_4 }}</option>
              <option value="Kit Recommendation Help">{{ section.settings.service_5 }}</option>
            </select>
            <span class="contact-form__select-arrow" aria-hidden="true">
              <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1L6 7L11 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              </svg>
            </span>
          </div>
        </div>

        <!-- Tell Us About Your Event -->
        <div class="contact-form__field contact-form__field--textarea">
          <label class="contact-form__label" for="ContactForm-body">
            {{ section.settings.label_body }}
          </label>
          <textarea
            class="contact-form__textarea"
            id="ContactForm-body"
            name="contact[body]"
            rows="5"
            placeholder="{{ section.settings.placeholder_body }}"
          >{{ form.body }}</textarea>
        </div>

        <!-- Submit -->
        <button type="submit" class="contact-form__submit btn btn--primary btn--full">
          {{ section.settings.submit_label }}
        </button>

      {% endform %}
      </div><!-- /.contact-card -->
    </div>

  </div>
</section>

{% stylesheet %}

/* =============================================
   CONTACT SECTION
   ============================================= */

.contact-section {
  background-color: var(--color-surface, #fff8f4);
  padding: 10rem 0 4rem;
}

.contact-section__inner {
  max-width: 1300px;
  margin: 0 auto;
  padding: 0 2rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
}

/* --- Left Column --- */

.contact-section__heading {
  font-family: 'Epilogue', sans-serif;
  font-weight: 900;
  font-size: clamp(3.5rem, 6vw, 6.5rem);
  line-height: 0.92;
  text-transform: uppercase;
  color: var(--color-primary, #002542);
  letter-spacing: -0.03em;
  margin: 0 0 2rem;
}

.contact-section__intro {
  font-family: 'Manrope', sans-serif;
  font-size: 0.95rem;
  line-height: 1.75;
  color: var(--color-on-surface-variant, #8a7560);
  margin: 0 0 2.25rem;
  max-width: 400px;
}

.contact-section__services {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
}

.contact-section__services li {
  font-family: 'Manrope', sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--color-on-surface, #281801);
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.contact-section__services li::before {
  content: '';
  display: inline-block;
  width: 6px;
  height: 6px;
  background-color: var(--color-secondary, #725a39);
  flex-shrink: 0;
}

/* --- Right Column — White Card --- */

.contact-card {
  background: #ffffff;
  padding: 3rem 3.5rem 3.5rem;
  box-shadow: 0 4px 32px rgba(0, 37, 66, 0.08), 0 1px 4px rgba(0, 37, 66, 0.06);
  border-top: 3px solid var(--color-primary, #002542);
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.contact-form__field {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.contact-form__label {
  font-family: 'Manrope', sans-serif;
  font-weight: 800;
  font-size: 0.65rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--color-primary, #002542);
}

.contact-form__input,
.contact-form__textarea,
.contact-form__select {
  width: 100%;
  background: transparent;
  border: none;
  border-bottom: 1px solid rgba(0, 37, 66, 0.18);
  padding: 0.75rem 0;
  font-family: 'Manrope', sans-serif;
  font-size: 0.9rem;
  color: var(--color-primary, #002542);
  outline: none;
  transition: border-color 0.2s ease;
  border-radius: 0 !important;
  -webkit-appearance: none;
  appearance: none;
}

.contact-form__input::placeholder,
.contact-form__textarea::placeholder {
  font-family: 'Manrope', sans-serif;
  font-weight: 700;
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(0, 37, 66, 0.3);
}

.contact-form__input:focus,
.contact-form__textarea:focus,
.contact-form__select:focus {
  border-bottom-color: var(--color-primary, #002542);
}

/* Select wrapper for custom arrow */
.contact-form__select-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.contact-form__select {
  cursor: pointer;
  padding-right: 2rem;
}

.contact-form__select option[value=""][disabled] {
  font-weight: 700;
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(0, 37, 66, 0.3);
}

.contact-form__select-arrow {
  position: absolute;
  right: 0.25rem;
  pointer-events: none;
  color: var(--color-primary, #002542);
  display: flex;
  align-items: center;
}

/* Textarea */
.contact-form__textarea {
  resize: none;
  min-height: 120px;
  line-height: 1.65;
}

/* Submit button */
.contact-form__submit {
  margin-top: 0.5rem;
  padding: 1.6rem 2rem;
  font-size: 0.9rem;
  letter-spacing: 0.3em;
}

/* Success message */
.contact-form__success {
  font-family: 'Manrope', sans-serif;
  font-weight: 700;
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  color: var(--color-secondary, #725a39);
  padding: 1rem 0;
  border-bottom: 1px solid rgba(114, 90, 57, 0.3);
  margin-bottom: 0.5rem;
}

/* --- Responsive --- */
@media (max-width: 900px) {
  .contact-section__inner {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .contact-section {
    padding: 7rem 0 3rem;
  }

  .contact-section__intro {
    max-width: 100%;
  }
}

@media (max-width: 600px) {
  .contact-section {
    padding: 5rem 0 2.5rem;
  }

  .contact-section__inner {
    padding: 0 1.25rem;
  }

  .contact-card {
    padding: 2rem 1.5rem 2.5rem;
  }
}

{% endstylesheet %}

{% schema %}
{
  "name": "Contact Page",
  "tag": "section",
  "class": "shopify-section--contact",
  "settings": [
    {
      "type": "header",
      "content": "Left Column"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Initiate Contact"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Intro Text",
      "default": "Ready to book a service or have questions about which kit is right for you? Fill out the form and we will be in touch within one business day."
    },
    {
      "type": "header",
      "content": "Service List Items"
    },
    {
      "type": "text",
      "id": "service_1",
      "label": "Service 1",
      "default": "Custom Retreat Planning"
    },
    {
      "type": "text",
      "id": "service_2",
      "label": "Service 2",
      "default": "Day-Of Coordination"
    },
    {
      "type": "text",
      "id": "service_3",
      "label": "Service 3",
      "default": "Planning Consultation"
    },
    {
      "type": "text",
      "id": "service_4",
      "label": "Service 4",
      "default": "Full Event Management"
    },
    {
      "type": "text",
      "id": "service_5",
      "label": "Service 5",
      "default": "Kit Recommendation Help"
    },
    {
      "type": "header",
      "content": "Form Labels"
    },
    {
      "type": "text",
      "id": "label_name",
      "label": "Name Field Label",
      "default": "Full Name"
    },
    {
      "type": "text",
      "id": "placeholder_name",
      "label": "Name Placeholder",
      "default": "Required"
    },
    {
      "type": "text",
      "id": "label_email",
      "label": "Email Field Label",
      "default": "Email Address"
    },
    {
      "type": "text",
      "id": "placeholder_email",
      "label": "Email Placeholder",
      "default": "you@domain.com"
    },
    {
      "type": "text",
      "id": "label_interest",
      "label": "Interest Field Label",
      "default": "I Am Interested In"
    },
    {
      "type": "text",
      "id": "placeholder_interest",
      "label": "Interest Placeholder",
      "default": "Select One..."
    },
    {
      "type": "text",
      "id": "label_body",
      "label": "Message Field Label",
      "default": "Tell Us About Your Event"
    },
    {
      "type": "text",
      "id": "placeholder_body",
      "label": "Message Placeholder",
      "default": "Event type, date, group size, goals..."
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit Button Text",
      "default": "Submit Inquiry"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "Thank you for reaching out. We will be in touch within one business day."
    }
  ],
  "presets": [
    {
      "name": "Contact Page"
    }
  ]
}
{% endschema %}
