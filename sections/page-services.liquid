<!-- ============================================================
   SERVICES PAGE SECTION
   Planning Services grid + The Blueprint process steps
   ============================================================ -->

<!-- ---- PLANNING SERVICES GRID ---- -->
<section class="svc-grid" {{ section.shopify_attributes }}>
  <div class="svc-grid__inner">

    <!-- Page Header -->
    <div class="svc-grid__header">
      <div class="svc-grid__header-left">
        <h1 class="svc-grid__page-title">{{ section.settings.page_title }}</h1>
      </div>
      <div class="svc-grid__header-right">
        <p class="svc-grid__brand-label">{{ section.settings.brand_label }}</p>
        <p class="svc-grid__brand-tagline">{{ section.settings.brand_tagline }}</p>
      </div>
    </div>

    <div class="svc-grid__divider"></div>

    <!-- 2x2 Service Cards Grid -->
    <div class="svc-grid__cards">

      <!-- Card 01 -->
      <div class="svc-card svc-card--light">
        <div class="svc-card__num-wrap">
          <span class="svc-card__num">01</span>
        </div>
        <div class="svc-card__content">
          <p class="svc-card__tag">{{ section.settings.card1_tag }}</p>
          <h2 class="svc-card__title">{{ section.settings.card1_title }}</h2>
          <p class="svc-card__desc">{{ section.settings.card1_desc }}</p>
          <p class="svc-card__price">{{ section.settings.card1_price_label }} <strong>{{ section.settings.card1_price }}</strong></p>
          <a href="{{ section.settings.card1_link }}" class="svc-card__cta">
            {{ section.settings.card1_cta }} &rarr;
          </a>
        </div>
      </div>

      <!-- Card 02 -->
      <div class="svc-card svc-card--warm">
        <div class="svc-card__num-wrap">
          <span class="svc-card__num">02</span>
        </div>
        <div class="svc-card__content">
          <p class="svc-card__tag">{{ section.settings.card2_tag }}</p>
          <h2 class="svc-card__title">{{ section.settings.card2_title }}</h2>
          <p class="svc-card__desc">{{ section.settings.card2_desc }}</p>
          <p class="svc-card__price">{{ section.settings.card2_price_label }} <strong>{{ section.settings.card2_price }}</strong></p>
          <a href="{{ section.settings.card2_link }}" class="svc-card__cta">
            {{ section.settings.card2_cta }} &rarr;
          </a>
        </div>
      </div>

      <!-- Card 03 -->
      <div class="svc-card svc-card--light">
        <div class="svc-card__num-wrap">
          <span class="svc-card__num">03</span>
        </div>
        <div class="svc-card__content">
          <p class="svc-card__tag">{{ section.settings.card3_tag }}</p>
          <h2 class="svc-card__title">{{ section.settings.card3_title }}</h2>
          <p class="svc-card__desc">{{ section.settings.card3_desc }}</p>
          <p class="svc-card__price">{{ section.settings.card3_price_label }} <strong>{{ section.settings.card3_price }}</strong></p>
          <a href="{{ section.settings.card3_link }}" class="svc-card__cta">
            {{ section.settings.card3_cta }} &rarr;
          </a>
        </div>
      </div>

      <!-- Card 04 -->
      <div class="svc-card svc-card--light">
        <div class="svc-card__num-wrap">
          <span class="svc-card__num">04</span>
        </div>
        <div class="svc-card__content">
          <p class="svc-card__tag">{{ section.settings.card4_tag }}</p>
          <h2 class="svc-card__title">{{ section.settings.card4_title }}</h2>
          <p class="svc-card__desc">{{ section.settings.card4_desc }}</p>
          <p class="svc-card__price">{{ section.settings.card4_price_label }}</p>
          <a href="{{ section.settings.card4_link }}" class="svc-card__cta">
            {{ section.settings.card4_cta }} &rarr;
          </a>
        </div>
      </div>

    </div><!-- /.svc-grid__cards -->
  </div><!-- /.svc-grid__inner -->
</section>

<!-- ---- THE BLUEPRINT PROCESS STEPS ---- -->
<section class="blueprint" id="blueprint">
  <div class="blueprint__inner">

    <div class="blueprint__left">
      <h2 class="blueprint__heading">{{ section.settings.bp_heading }}</h2>
      <p class="blueprint__subtext">{{ section.settings.bp_subtext }}</p>
    </div>

    <div class="blueprint__steps">

      <div class="blueprint__step">
        <div class="blueprint__step-num-wrap">
          <span class="blueprint__step-num">01</span>
        </div>
        <div class="blueprint__step-content">
          <h3 class="blueprint__step-title">{{ section.settings.step1_title }}</h3>
          <p class="blueprint__step-desc">{{ section.settings.step1_desc }}</p>
        </div>
      </div>

      <div class="blueprint__step">
        <div class="blueprint__step-num-wrap">
          <span class="blueprint__step-num">02</span>
        </div>
        <div class="blueprint__step-content">
          <h3 class="blueprint__step-title">{{ section.settings.step2_title }}</h3>
          <p class="blueprint__step-desc">{{ section.settings.step2_desc }}</p>
        </div>
      </div>

      <div class="blueprint__step">
        <div class="blueprint__step-num-wrap">
          <span class="blueprint__step-num">03</span>
        </div>
        <div class="blueprint__step-content">
          <h3 class="blueprint__step-title">{{ section.settings.step3_title }}</h3>
          <p class="blueprint__step-desc">{{ section.settings.step3_desc }}</p>
        </div>
      </div>

    </div><!-- /.blueprint__steps -->
  </div><!-- /.blueprint__inner -->
</section>

{% stylesheet %}

/* =============================================
   SERVICES GRID
   ============================================= */

.svc-grid {
  background-color: var(--color-surface, #fff8f4);
  padding: 6rem 0 0;
}

.svc-grid__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 2rem;
}

/* Header row */
.svc-grid__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 2.5rem;
}

.svc-grid__page-title {
  font-family: 'Epilogue', sans-serif;
  font-weight: 900;
  font-size: clamp(3.5rem, 8vw, 7rem);
  line-height: 0.95;
  text-transform: uppercase;
  color: var(--color-primary, #002542);
  letter-spacing: -0.03em;
  margin: 0;
}

.svc-grid__header-right {
  text-align: right;
  padding-top: 0.5rem;
}

.svc-grid__brand-label {
  font-family: 'Manrope', sans-serif;
  font-weight: 800;
  font-size: 0.6rem;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--color-primary, #002542);
  margin: 0 0 0.25rem;
}

.svc-grid__brand-tagline {
  font-family: 'Manrope', sans-serif;
  font-size: 0.85rem;
  color: var(--color-on-surface-variant, #8a7560);
  margin: 0;
  font-style: italic;
}

.svc-grid__divider {
  width: 100%;
  height: 1px;
  background-color: rgba(0, 37, 66, 0.15);
  margin-bottom: 0;
}

/* Cards grid */
.svc-grid__cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: auto auto;
  border-top: 1px solid rgba(0, 37, 66, 0.15);
}

.svc-card {
  position: relative;
  padding: 4rem 3rem;
  border-bottom: 1px solid rgba(0, 37, 66, 0.12);
  border-right: 1px solid rgba(0, 37, 66, 0.12);
  display: flex;
  flex-direction: column;
  gap: 0;
  min-height: 340px;
}

/* Remove right border on last column */
.svc-card:nth-child(2n) {
  border-right: none;
}

.svc-card--light {
  background-color: var(--color-surface, #fff8f4);
}

.svc-card--warm {
  background-color: var(--color-surface-container, #ffebd3);
}

.svc-card__num-wrap {
  position: absolute;
  top: 2.5rem;
  right: 2.5rem;
}

.svc-card__num {
  font-family: 'Epilogue', sans-serif;
  font-weight: 900;
  font-size: 4rem;
  line-height: 1;
  color: rgba(0, 37, 66, 0.08);
  letter-spacing: -0.05em;
}

.svc-card__tag {
  font-family: 'Manrope', sans-serif;
  font-weight: 800;
  font-size: 0.6rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--color-secondary, #725a39);
  margin: 0 0 1rem;
}

.svc-card__title {
  font-family: 'Epilogue', sans-serif;
  font-weight: 900;
  font-size: clamp(1.4rem, 2.5vw, 1.85rem);
  line-height: 1.05;
  text-transform: uppercase;
  color: var(--color-primary, #002542);
  letter-spacing: -0.02em;
  margin: 0 0 1.25rem;
}

.svc-card__desc {
  font-family: 'Manrope', sans-serif;
  font-size: 0.95rem;
  line-height: 1.65;
  color: var(--color-on-surface-variant, #8a7560);
  margin: 0 0 1.5rem;
  max-width: 340px;
}

.svc-card__price {
  font-family: 'Manrope', sans-serif;
  font-weight: 700;
  font-size: 0.7rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--color-primary, #002542);
  margin: 0 0 1.25rem;
}

.svc-card__price strong {
  color: var(--color-secondary, #725a39);
}

.svc-card__cta {
  display: inline-block;
  font-family: 'Manrope', sans-serif;
  font-weight: 800;
  font-size: 0.65rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--color-primary, #002542);
  text-decoration: underline;
  text-underline-offset: 4px;
  transition: color 0.2s ease;
  margin-top: auto;
}

.svc-card__cta:hover {
  color: var(--color-secondary, #725a39);
}

/* =============================================
   THE BLUEPRINT
   ============================================= */

.blueprint {
  background-color: var(--color-surface-container, #ffebd3);
  padding: 7rem 0;
}

.blueprint__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 2rem;
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 5rem;
  align-items: start;
}

.blueprint__heading {
  font-family: 'Epilogue', sans-serif;
  font-weight: 900;
  font-size: clamp(3rem, 5vw, 5rem);
  line-height: 1;
  text-transform: uppercase;
  color: var(--color-primary, #002542);
  letter-spacing: -0.03em;
  margin: 0 0 1.25rem;
}

.blueprint__subtext {
  font-family: 'Manrope', sans-serif;
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--color-on-surface-variant, #8a7560);
  margin: 0;
  max-width: 260px;
}

.blueprint__steps {
  display: flex;
  flex-direction: column;
  gap: 4rem;
}

.blueprint__step {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: 2rem;
  align-items: start;
}

.blueprint__step-num-wrap {
  display: flex;
  align-items: flex-start;
  padding-top: 0.2rem;
}

.blueprint__step-num {
  font-family: 'Epilogue', sans-serif;
  font-weight: 900;
  font-size: 3.5rem;
  line-height: 1;
  color: rgba(0, 37, 66, 0.18);
  letter-spacing: -0.05em;
}

.blueprint__step-title {
  font-family: 'Epilogue', sans-serif;
  font-weight: 900;
  font-size: 1.3rem;
  text-transform: uppercase;
  color: var(--color-primary, #002542);
  letter-spacing: -0.01em;
  margin: 0 0 0.75rem;
}

.blueprint__step-desc {
  font-family: 'Manrope', sans-serif;
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--color-on-surface-variant, #8a7560);
  margin: 0;
  max-width: 520px;
}

/* Responsive */
@media (max-width: 900px) {
  .svc-grid__cards {
    grid-template-columns: 1fr;
  }
  .svc-card {
    border-right: none;
  }
  .svc-grid__header {
    flex-direction: column;
    gap: 1rem;
  }
  .svc-grid__header-right {
    text-align: left;
  }
  .blueprint__inner {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .blueprint__subtext {
    max-width: 100%;
  }
  .blueprint__step {
    grid-template-columns: 60px 1fr;
    gap: 1.5rem;
  }
}

{% endstylesheet %}

