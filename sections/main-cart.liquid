<section class="cart-page" {{ section.shopify_attributes }}>
  <div class="cart-page__inner">

    <h1 class="cart-page__title">{{ 'cart.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
      {%- form 'cart', cart, id: 'CartForm' -%}

        <div class="cart-page__layout">

          <!-- Items -->
          <div class="cart-page__items">
            {%- for item in cart.items -%}
              <div class="cart-item">
                <div class="cart-item__image">
                  {%- if item.image -%}
                    <img
                      src="{{ item.image | image_url: width: 200 }}"
                      alt="{{ item.image.alt | escape }}"
                      loading="lazy"
                      width="200"
                    >
                  {%- endif -%}
                </div>
                <div class="cart-item__info">
                  <h3 class="cart-item__title">{{ item.product.title | upcase }}</h3>
                  {%- unless item.variant.title == 'Default Title' -%}
                    <span class="cart-item__variant">{{ item.variant.title }}</span>
                  {%- endunless -%}
                  <div class="cart-item__price">
                    {%- if item.original_line_price != item.final_line_price -%}
                      <span class="price--sale">{{ item.final_line_price | money }}</span>
                      <span class="price--compare">{{ item.original_line_price | money }}</span>
                    {%- else -%}
                      <span>{{ item.original_line_price | money }}</span>
                    {%- endif -%}
                  </div>
                </div>
                <div class="cart-item__qty">
                  <input
                    type="number"
                    name="updates[]"
                    id="updates_{{ item.id }}"
                    value="{{ item.quantity }}"
                    min="0"
                    class="qty-input"
                    aria-label="{{ 'products.product.quantity_label' | t }}"
                  >
                </div>
                <a class="cart-item__remove" href="{{ item.url_to_remove }}" aria-label="{{ 'cart.remove' | t }}">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                  </svg>
                </a>
              </div>
            {%- endfor -%}

            <div class="cart-page__update-row">
              <button class="btn btn--tertiary" name="update" type="submit">{{ 'cart.update' | t }}</button>
              <a class="btn btn--tertiary" href="{{ routes.collections_url }}">{{ 'cart.continue_shopping' | t }}</a>
            </div>
          </div>

          <!-- Summary -->
          <div class="cart-page__summary">
            <div class="cart-summary">
              <h2 class="cart-summary__title">ORDER SUMMARY</h2>
              <div class="cart-summary__line">
                <span>{{ 'cart.subtotal' | t }}</span>
                <span>{{ cart.total_price | money }}</span>
              </div>
              {%- if cart.cart_level_discount_applications.size > 0 -%}
                {%- for discount in cart.cart_level_discount_applications -%}
                  <div class="cart-summary__line cart-summary__line--discount">
                    <span>{{ discount.title }}</span>
                    <span>-{{ discount.total_allocated_amount | money }}</span>
                  </div>
                {%- endfor -%}
              {%- endif -%}
              <div class="cart-summary__divider"></div>
              <div class="cart-summary__line cart-summary__line--total">
                <span>TOTAL</span>
                <span>{{ cart.total_price | money }}</span>
              </div>
              <button class="btn btn--primary btn--full" type="submit" name="checkout">
                {{ 'cart.checkout' | t }}
              </button>
              <p class="cart-summary__note">Digital downloads delivered instantly after purchase.</p>
            </div>
          </div>
        </div>
      {%- endform -%}

    {%- else -%}
      <div class="cart-page__empty">
        <p class="cart-page__empty-text">{{ 'cart.empty' | t }}</p>
        <a class="btn btn--primary" href="{{ routes.collections_url }}">{{ 'cart.browse_products' | t }}</a>
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
  .cart-page { padding: 8rem 0 5rem; min-height: 70vh; background-color: var(--color-surface); }

  .cart-page__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .cart-page__title {
    font-family: 'Epilogue', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 5vw, 4rem);
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 3rem;
    letter-spacing: -0.02em;
  }

  .cart-page__layout {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 100px 1fr auto auto;
    gap: 1.5rem;
    align-items: center;
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(195, 198, 206, 0.3);
  }

  .cart-item__image {
    aspect-ratio: 1;
    overflow: hidden;
    background-color: var(--color-surface-container-low);
  }

  .cart-item__image img { width: 100%; height: 100%; object-fit: cover; }

  .cart-item__title {
    font-family: 'Epilogue', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-primary);
    margin: 0 0 0.5rem;
  }

  .cart-item__variant {
    display: block;
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    color: var(--color-on-surface-variant);
    margin-bottom: 0.5rem;
  }

  .cart-item__price {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-primary);
  }

  .cart-item__qty .qty-input {
    width: 56px;
    height: 40px;
    text-align: center;
    border: 2px solid var(--color-surface-container);
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-on-surface);
    background: transparent;
    outline: none;
  }

  .cart-item__remove {
    color: var(--color-on-surface-variant);
    transition: color 0.2s ease;
  }
  .cart-item__remove:hover { color: #ba1a1a; }

  .cart-page__update-row {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem 0;
  }

  .cart-summary {
    background-color: var(--color-surface-container-low);
    padding: 2.5rem;
    position: sticky;
    top: 6rem;
  }

  .cart-summary__title {
    font-family: 'Epilogue', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 1.5rem;
    letter-spacing: 0.05em;
  }

  .cart-summary__line {
    display: flex;
    justify-content: space-between;
    font-family: 'Manrope', sans-serif;
    font-size: 0.95rem;
    color: var(--color-on-surface-variant);
    margin-bottom: 0.75rem;
  }

  .cart-summary__line--discount { color: var(--color-secondary); }

  .cart-summary__line--total {
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--color-on-surface);
    margin-top: 0.75rem;
  }

  .cart-summary__divider {
    height: 1px;
    background-color: rgba(195, 198, 206, 0.3);
    margin: 1rem 0;
  }

  .btn--full { width: 100%; margin-top: 1.5rem; }

  .cart-summary__note {
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    text-align: center;
    color: var(--color-on-surface-variant);
    margin: 1rem 0 0;
    line-height: 1.5;
  }

  .cart-page__empty {
    text-align: center;
    padding: 5rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .cart-page__empty-text {
    font-family: 'Epilogue', sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
  }

  .price--sale { color: #ba1a1a; margin-right: 0.5rem; }
  .price--compare { text-decoration: line-through; opacity: 0.5; }

  @media (max-width: 768px) {
    .cart-page__layout { grid-template-columns: 1fr; }
    .cart-item { grid-template-columns: 80px 1fr; }
    .cart-item__qty, .cart-item__remove { grid-column: 2; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "settings": []
}
{% endschema %}
