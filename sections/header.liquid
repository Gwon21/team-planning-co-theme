<nav class="site-header{% if section.settings.sticky_header %} site-header--sticky{% endif %}" role="navigation" aria-label="Main Navigation">
  <div class="site-header__inner">

    <!-- Logo -->
    <a class="site-header__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
      {%- if settings.logo != blank -%}
        <img
          src="{{ settings.logo | image_url: width: 320 }}"
          alt="{{ shop.name }}"
          width="{{ settings.logo_max_width }}"
          loading="eager"
        >
      {%- else -%}
        <span class="site-header__logo-text">{{ settings.logo_text | default: shop.name }}</span>
      {%- endif -%}
    </a>

    <!-- Desktop Navigation -->
    <div class="site-header__nav hide-mobile" aria-label="Main menu">
      {%- if section.settings.menu != blank -%}
        {%- assign menu = linklists[section.settings.menu] -%}
        {%- for link in menu.links -%}
          <a
            class="site-header__nav-link{% if link.active %} active{% endif %}"
            href="{{ link.url }}"
            {% if link.current %}aria-current="page"{% endif %}
          >
            {{ link.title | upcase }}
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <!-- Header Actions -->
    <div class="site-header__actions">

      <!-- Contact Button (desktop only) -->
      <a
        class="site-header__contact-btn hide-mobile"
        href="{{ section.settings.contact_url }}"
      >
        {{ section.settings.contact_label }}
      </a>

      <!-- Search -->
      <button
        class="site-header__icon-btn"
        aria-label="{{ 'sections.header.search' | t }}"
        data-action="open-search"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>

      <!-- Cart -->
      <a
        class="site-header__icon-btn site-header__cart-btn"
        href="{{ routes.cart_url }}"
        aria-label="{{ 'sections.header.cart' | t: count: cart.item_count }}"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

      <!-- Mobile Menu Toggle -->
      <button
        class="site-header__icon-btn site-header__mobile-toggle show-mobile"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav-overlay"
        data-action="toggle-mobile-menu"
      >
        <!-- Hamburger lines -->
        <span class="burger-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <!-- X icon -->
        <svg class="close-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

    </div>
  </div>
</nav>

<!-- ============================================================
   FULL-SCREEN MOBILE NAV OVERLAY
   Slides in from the right. Does NOT push page content down.
   ============================================================ -->
<div
  class="mobile-nav-overlay show-mobile"
  id="mobile-nav-overlay"
  aria-hidden="true"
  role="dialog"
  aria-label="Mobile navigation"
>
  <!-- Nav links — large, centered, easy to tap -->
  <nav class="mobile-nav-overlay__nav">
    {%- if section.settings.menu != blank -%}
      {%- assign menu = linklists[section.settings.menu] -%}
      {%- for link in menu.links -%}
        <a
          class="mobile-nav-overlay__link{% if link.active %} active{% endif %}"
          href="{{ link.url }}"
        >
          {{ link.title }}
        </a>
      {%- endfor -%}
    {%- endif -%}
    <a href="{{ routes.cart_url }}" class="mobile-nav-overlay__link">
      Cart{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}
    </a>
  </nav>

  <!-- Contact CTA at the bottom of the overlay -->
  {%- if section.settings.contact_url != blank -%}
    <div class="mobile-nav-overlay__footer">
      <a class="btn btn--secondary" href="{{ section.settings.contact_url }}">
        {{ section.settings.contact_label | default: 'Contact Us' | upcase }}
      </a>
    </div>
  {%- endif -%}
</div>

<!-- Dimmed backdrop (behind overlay, closes menu when tapped) -->
<div class="mobile-nav-backdrop show-mobile" id="mobile-nav-backdrop" aria-hidden="true"></div>

{% stylesheet %}
  /* ---- Site Header ---- */
  .site-header {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 200;
    background-color: rgba(255, 248, 244, 0.92);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow: 0 2px 20px 0 rgba(40, 24, 1, 0.07);
    transition: background-color 0.3s ease;
  }

  .site-header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 2rem;
    max-width: 1440px;
    margin: 0 auto;
    gap: 2rem;
  }

  .site-header__logo {
    text-decoration: none;
    flex-shrink: 0;
    position: relative;
    z-index: 201; /* stays above overlay */
  }

  .site-header__logo img {
    max-width: var(--logo-max-width, 160px);
    height: auto;
    display: block;
  }

  .site-header__logo-text {
    font-family: 'Epilogue', sans-serif;
    font-weight: 900;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
    color: var(--color-primary);
    text-transform: uppercase;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .site-header__nav-link {
    font-family: 'Epilogue', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-header__nav-link:hover,
  .site-header__nav-link.active {
    color: var(--color-primary);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
    position: relative;
    z-index: 201;
  }

  .site-header__contact-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary, #002542);
    color: #ffffff;
    font-family: 'Epilogue', sans-serif;
    font-weight: 800;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.55rem 1.25rem;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
    white-space: nowrap;
    border-radius: 0 !important;
    min-height: 44px;
  }

  .site-header__contact-btn:hover {
    opacity: 0.82;
  }

  .site-header__icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-primary);
    padding: 0.5rem;
    position: relative;
    transition: opacity 0.2s ease;
    min-width: 44px;
    min-height: 44px;
    border-radius: 0;
  }

  .site-header__icon-btn:hover {
    opacity: 0.7;
  }

  .cart-count {
    position: absolute;
    top: 4px;
    right: 4px;
    background-color: var(--color-secondary);
    color: #fff;
    font-family: 'Manrope', sans-serif;
    font-weight: 800;
    font-size: 0.6rem;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ---- Animated Burger Icon ---- */
  .burger-icon {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 22px;
    height: 22px;
    transition: opacity 0.2s ease;
  }

  .burger-icon span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-primary);
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .close-icon {
    position: absolute;
    opacity: 0;
    transform: rotate(-45deg) scale(0.7);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  /* Menu open state: hide burger lines, show X */
  .site-header__mobile-toggle[aria-expanded="true"] .burger-icon span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .site-header__mobile-toggle[aria-expanded="true"] .burger-icon span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .site-header__mobile-toggle[aria-expanded="true"] .burger-icon span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ---- Full-Screen Mobile Nav Overlay ---- */
  .mobile-nav-overlay {
    display: none; /* shown only on mobile via .show-mobile */
    position: fixed;
    top: 0;
    right: 0;
    width: 100%;
    height: 100%;
    z-index: 199; /* just below header (200) */
    background-color: var(--color-primary, #002542);
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    /* Top padding clears the fixed header */
    padding-top: calc(var(--header-height, 70px) + 1.5rem);
    padding-left: 2rem;
    padding-right: 2rem;
    padding-bottom: calc(3rem + env(safe-area-inset-bottom, 0px));
    flex-direction: column;
    justify-content: center;
  }

  .mobile-nav-overlay.is-open {
    transform: translateX(0);
  }

  .mobile-nav-overlay__nav {
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }

  .mobile-nav-overlay__link {
    display: block;
    font-family: 'Epilogue', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 8vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--color-inverse-on-surface, #ffeedb);
    text-decoration: none;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(255, 238, 219, 0.08);
    transition: color 0.2s ease, padding-left 0.2s ease;
    /* Ensure tappable */
    min-height: 60px;
  }

  .mobile-nav-overlay__link:hover,
  .mobile-nav-overlay__link:focus,
  .mobile-nav-overlay__link.active {
    color: var(--color-secondary, #c9a96e);
    padding-left: 0.5rem;
  }

  .mobile-nav-overlay__footer {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 238, 219, 0.1);
  }

  .mobile-nav-overlay__footer .btn {
    width: 100%;
    justify-content: center;
  }

  /* ---- Dimmed Backdrop ---- */
  .mobile-nav-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 198; /* below overlay (199) */
    background-color: rgba(0, 0, 0, 0.5);
    opacity: 0;
    transition: opacity 0.4s ease;
    backdrop-filter: blur(2px);
  }

  .mobile-nav-backdrop.is-visible {
    opacity: 1;
  }

  /* ---- Responsive Visibility ---- */
  @media (max-width: 768px) {
    .hide-mobile { display: none !important; }
    .show-mobile { display: flex !important; }
    .mobile-nav-overlay { display: flex; }
    .mobile-nav-backdrop { display: block; }
    .site-header__inner { padding: 0.75rem 1.25rem; }

    /* Keep logo text visible in light color when overlay is open */
    .site-header.menu-is-open .site-header__logo-text {
      color: var(--color-primary);
    }
  }

  @media (min-width: 769px) {
    .show-mobile { display: none !important; }
    /* Force closed on desktop */
    .mobile-nav-overlay {
      transform: translateX(100%) !important;
    }
    .mobile-nav-backdrop {
      display: none !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky Header",
      "default": true
    },
    {
      "type": "header",
      "content": "Contact Button"
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Button Label",
      "default": "Contact"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Button Link"
    }
  ]
}
{% endschema %}
