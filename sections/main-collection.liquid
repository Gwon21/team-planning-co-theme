<section class="collection-page" {{ section.shopify_attributes }}>

  <!-- Collection Header -->
  <div class="collection-page__header">
    <div class="collection-page__header-inner">
      <div>
        {%- if collection.image -%}
          <img
            class="collection-page__cover"
            src="{{ collection.image | image_url: width: 1200 }}"
            alt="{{ collection.title | escape }}"
            loading="eager"
            width="1200"
          >
        {%- endif -%}
        <h1 class="collection-page__title">{{ collection.title | upcase }}</h1>
        {%- if collection.description != blank -%}
          <p class="collection-page__desc">{{ collection.description }}</p>
        {%- endif -%}
      </div>
      <div class="collection-page__meta">
        <span>{{ collection.products_count }} {{ 'products.general.items_count' | t: count: collection.products_count }}</span>
      </div>
    </div>
  </div>

  <!-- Sort Bar -->
  <div class="collection-page__toolbar">
    <div class="collection-page__toolbar-inner">
      <span class="collection-page__count">
        Showing {{ collection.products.size }} of {{ collection.products_count }} kits
      </span>
      <div class="collection-page__sort">
        <label for="SortBy" class="collection-page__sort-label">{{ 'collections.general.sort_by_label' | t }}</label>
        <select id="SortBy" name="sort_by" class="collection-page__sort-select" onchange="location.href='?sort_by=' + this.value">
          {%- assign sort_options = 'manual,best_selling,title_ascending,title_descending,price_ascending,price_descending,created_descending' | split: ',' -%}
          {%- for opt in sort_options -%}
            <option value="{{ opt }}"{% if collection.sort_by == opt %} selected{% endif %}>
              {{ 'collections.sort_options.' | append: opt | t | default: opt }}
            </option>
          {%- endfor -%}
        </select>
      </div>
    </div>
  </div>

  <!-- Product Grid -->
  <div class="collection-page__grid-wrap">
    <div class="collection-page__grid">
      {%- if collection.products.size == 0 -%}
        <div class="collection-page__empty">
          <p>{{ 'products.general.no_products' | t }}</p>
          <a class="btn btn--primary" href="{{ routes.root_url }}">Back to Home</a>
        </div>
      {%- else -%}
        {%- for product in collection.products -%}
          <div class="collection-product-card{% cycle '', '', ' collection-product-card--offset' %}">
            {% render 'product-card', product: product %}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>

  <!-- Pagination -->
  {%- if paginate.pages > 1 -%}
    <div class="collection-page__pagination">
      {{ paginate | default_pagination }}
    </div>
  {%- endif -%}

</section>

{% stylesheet %}
  .collection-page { padding-top: 6rem; min-height: 80vh; }

  .collection-page__header {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-container) 100%);
    padding: 5rem 0 4rem;
    position: relative;
    overflow: hidden;
  }

  .collection-page__header-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
  }

  .collection-page__cover {
    width: 100%;
    max-height: 300px;
    object-fit: cover;
    position: absolute;
    inset: 0;
    opacity: 0.12;
    z-index: 0;
  }

  .collection-page__title {
    font-family: 'Epilogue', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--color-inverse-on-surface);
    margin: 0 0 1rem;
    position: relative;
    z-index: 1;
  }

  .collection-page__desc {
    font-family: 'Manrope', sans-serif;
    font-size: 1.05rem;
    line-height: 1.65;
    color: rgba(255, 238, 219, 0.65);
    max-width: 560px;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .collection-page__meta {
    text-align: right;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .collection-page__meta span {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 238, 219, 0.45);
  }

  .collection-page__toolbar {
    background-color: var(--color-surface-container-low);
    border-bottom: 1px solid rgba(195, 198, 206, 0.2);
  }

  .collection-page__toolbar-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .collection-page__count {
    font-family: 'Manrope', sans-serif;
    font-size: 0.8rem;
    color: var(--color-on-surface-variant);
  }

  .collection-page__sort {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .collection-page__sort-label {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
  }

  .collection-page__sort-select {
    background: none;
    border: none;
    font-family: 'Manrope', sans-serif;
    font-size: 0.85rem;
    color: var(--color-primary);
    font-weight: 700;
    cursor: pointer;
    outline: none;
  }

  .collection-page__grid-wrap {
    max-width: 1440px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .collection-page__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem 2rem;
  }

  .collection-product-card--offset { margin-top: 3rem; }

  .collection-page__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 5rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    font-family: 'Manrope', sans-serif;
    color: var(--color-on-surface-variant);
  }

  .collection-page__pagination {
    max-width: 1440px;
    margin: 0 auto;
    padding: 2rem;
    text-align: center;
  }

  .collection-page__pagination a, .collection-page__pagination span {
    font-family: 'Manrope', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.6rem 1rem;
    color: var(--color-primary);
    text-decoration: none;
    border: 2px solid transparent;
    transition: border-color 0.2s ease;
  }

  .collection-page__pagination a:hover { border-color: var(--color-primary); }
  .collection-page__pagination .current { border-color: var(--color-primary); }

  @media (max-width: 900px) {
    .collection-page__grid { grid-template-columns: 1fr 1fr; }
    .collection-product-card--offset { margin-top: 0; }
    .collection-page__header-inner { flex-direction: column; align-items: flex-start; }
    .collection-page__meta { text-align: left; }
  }

  @media (max-width: 600px) {
    .collection-page__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Grid",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per Page",
      "min": 6,
      "max": 24,
      "step": 3,
      "default": 12
    }
  ]
}
{% endschema %}
