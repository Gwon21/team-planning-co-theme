<div class="auth-page">
  <div class="auth-page__inner">
    <h1 class="auth-page__title">{{ 'customer.login.title' | t }}</h1>

    {%- form 'customer_login' -%}
      {{ form.errors | default_errors }}
      <div class="auth-form__field">
        <label class="auth-form__label" for="CustomerEmail">{{ 'customer.login.email' | t | upcase }}</label>
        <input class="auth-form__input" type="email" name="customer[email]" id="CustomerEmail" autocomplete="email" required>
      </div>
      <div class="auth-form__field">
        <label class="auth-form__label" for="CustomerPassword">{{ 'customer.login.password' | t | upcase }}</label>
        <input class="auth-form__input" type="password" name="customer[password]" id="CustomerPassword" autocomplete="current-password" required>
      </div>
      <button class="btn btn--primary btn--full" type="submit">{{ 'customer.login.submit' | t | upcase }}</button>
      <div class="auth-form__links">
        <a href="/account/recover">{{ 'customer.login.forgot_password' | t }}</a>
        <a href="/account/register">{{ 'customer.login.create_account' | t }}</a>
      </div>
    {%- endform -%}
  </div>
</div>

<style>
  .auth-page { min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 8rem 2rem; background-color: var(--color-surface); }
  .auth-page__inner { width: 100%; max-width: 480px; }
  .auth-page__title { font-family: 'Epilogue', sans-serif; font-weight: 900; font-size: 2.5rem; text-transform: uppercase; color: var(--color-primary); margin: 0 0 2.5rem; letter-spacing: -0.02em; }
  .auth-form__field { margin-bottom: 1.5rem; }
  .auth-form__label { display: block; font-family: 'Manrope', sans-serif; font-weight: 800; font-size: 0.65rem; letter-spacing: 0.3em; color: var(--color-primary); margin-bottom: 0.5rem; }
  .auth-form__input { width: 100%; background: transparent; border: none; border-bottom: 2px solid rgba(0, 37, 66, 0.2); padding: 0.75rem 0; font-family: 'Manrope', sans-serif; font-size: 1rem; color: var(--color-on-surface); outline: none; transition: border-color 0.3s ease; box-sizing: border-box; }
  .auth-form__input:focus { border-bottom-color: var(--color-primary); }
  .auth-form__links { display: flex; justify-content: space-between; margin-top: 1.5rem; }
  .auth-form__links a { font-family: 'Manrope', sans-serif; font-size: 0.8rem; color: var(--color-secondary); text-decoration: underline; }
</style>
