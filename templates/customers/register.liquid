<div class="auth-page">
  <div class="auth-page__inner">
    <h1 class="auth-page__title">{{ 'customer.register.title' | t }}</h1>
    {%- form 'create_customer' -%}
      {{ form.errors | default_errors }}
      <div class="auth-form__field">
        <label class="auth-form__label" for="FirstName">{{ 'customer.register.first_name' | t | upcase }}</label>
        <input class="auth-form__input" type="text" name="customer[first_name]" id="FirstName" autocomplete="given-name">
      </div>
      <div class="auth-form__field">
        <label class="auth-form__label" for="LastName">{{ 'customer.register.last_name' | t | upcase }}</label>
        <input class="auth-form__input" type="text" name="customer[last_name]" id="LastName" autocomplete="family-name">
      </div>
      <div class="auth-form__field">
        <label class="auth-form__label" for="Email">{{ 'customer.register.email' | t | upcase }}</label>
        <input class="auth-form__input" type="email" name="customer[email]" id="Email" autocomplete="email" required>
      </div>
      <div class="auth-form__field">
        <label class="auth-form__label" for="CreatePassword">{{ 'customer.register.password' | t | upcase }}</label>
        <input class="auth-form__input" type="password" name="customer[password]" id="CreatePassword" autocomplete="new-password" required>
      </div>
      <button class="btn btn--primary btn--full" type="submit">{{ 'customer.register.submit' | t | upcase }}</button>
      <div class="auth-form__links">
        <a href="/account/login">{{ 'customer.register.login' | t }}</a>
      </div>
    {%- endform -%}
  </div>
</div>
